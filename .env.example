# Arivo Web App — Environment Variables

# Backend API base (include /api suffix)
# Local:  http://localhost:10000/api
# Prod:   https://backend.arivoai.in/api
NEXT_PUBLIC_API_URL=/api
BACKEND_API_URL=https://backend.arivoai.in/api

# Marketing
NEXT_PUBLIC_SITE_URL=https://arivoai.in
NEXT_PUBLIC_WEB3FORMS_ACCESS_KEY=

# Optional deep links
NEXT_PUBLIC_GOOGLE_PLAY_URL=https://play.google.com/store/apps/details?id=com.arivo
NEXT_PUBLIC_APP_LOGIN_URL=

# Google Sign-In (OAuth 2.0 client ID — Web application)
# Create in Google Cloud Console → APIs & Services → Credentials
# Authorized JavaScript origins: http://localhost:3000, https://arivoai.in
NEXT_PUBLIC_GOOGLE_CLIENT_ID=
